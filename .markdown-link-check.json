    { "pattern": "^https://codecov.io" },
    { "pattern": "^https://deepwiki.com" },
    { "pattern": "^https://img.shields.io" },
    { "pattern": "^https://github.com/.*/(blob|actions)" },
    { "pattern": "^mailto:" },
    { "pattern": "^https://redis-py.readthedocs.io" }
  ]
}
